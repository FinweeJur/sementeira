# Configuração do servidor da versão web. Copie para `.env` nesta mesma pasta.
# ESTE ARQUIVO NUNCA VAI PARA O NAVEGADOR — as chaves ficam só na máquina.

# Porta local. Quem expõe para a internet é o Cloudflare Tunnel, não esta porta.
SEMENTEIRA_PORTA=7010

# Token que libera as rotas de IA. Sem ele, /api/llm/* fica desligado.
# Gere um com:  node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
SEMENTEIRA_TOKEN=

# Chaves dos provedores. Só o que estiver preenchido aqui aparece como
# disponível em /api/saude.
DEEPSEEK_API_KEY=
MARITACA_API_KEY=
TAVILY_API_KEY=

# Ollama rodando na MESMA máquina do servidor (não na máquina de quem acessa).
OLLAMA_BASE_URL=http://127.0.0.1:11434

# ---------------------------------------------------------------------------
# Diretrizes e restrições do gateway de IA
#
# O gateway é a única porta de entrada remota para o Ollama desta máquina, e
# quem tem o token pode mandar qualquer prompt — a inferência roda no SEU
# hardware. As opções abaixo limitam isso. Todas têm padrão seguro o bastante
# para funcionar sem preencher nada.
# ---------------------------------------------------------------------------

# TRAVA DURA. `off` desliga o Ollama para quem vem da web, sem parar o Ollama
# local (o app instalado continua usando normalmente). Padrão: on.
SEMENTEIRA_OLLAMA_REMOTO=on

# TRAVA DURA. Lista de modelos que o gateway aceita, separados por vírgula.
# Vazio = qualquer modelo instalado. Ex.: llama3.2,mistral
OLLAMA_MODELOS_PERMITIDOS=

# TRAVAS DURAS de tamanho — impedem usar a máquina para moer contexto gigante.
SEMENTEIRA_MAX_MENSAGENS=60
SEMENTEIRA_MAX_CARACTERES=200000

# TRAVA DURA de taxa: chamadas de chat por minuto, por cliente. Inferência é o
# que pesa, por isso o teto é menor que o das demais rotas (20/min).
SEMENTEIRA_MAX_CHAT_MIN=10

# GUARDRAIL SUAVE. Injeta uma diretriz de escopo (mensagem `system`) em toda
# chamada do gateway, para o modelo recusar pedidos fora do escopo da
# Sementeira. Molda o comportamento, mas NÃO detém um abusador determinado —
# ele pode mandar o próprio `system`. Nunca conte com isto como segurança.
# Desligue com `off` se atrapalhar alguma resposta legítima.
SEMENTEIRA_DIRETRIZ_ESCOPO=on

# Log de auditoria (uma linha JSON por chamada: quem, provedor, modelo,
# tamanho — nunca o conteúdo). Vazio = escreve no stdout, que se perde quando o
# servidor roda como tarefa oculta. Preencha para conseguir auditar abuso.
SEMENTEIRA_LOG=
